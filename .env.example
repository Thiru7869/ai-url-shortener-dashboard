# Root .env.example — used as reference for docker-compose.yml defaults.
# For local (non-Docker) development, copy backend/.env.example -> backend/.env
# and frontend/.env.example -> frontend/.env instead.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=url_shortener

# --- Backend ---
BASE_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:4000
